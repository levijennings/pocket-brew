# Production Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Expo Configuration
EXPO_PUBLIC_EXPO_PROJECT_ID=your-expo-project-id
EAS_PROJECT_ID=your-eas-project-id
EXPO_TOKEN=your-eas-token

# App Configuration
EXPO_PUBLIC_APP_NAME=Pocket Brew
EXPO_PUBLIC_APP_VERSION=1.0.0
NODE_ENV=production

# API Configuration
EXPO_PUBLIC_API_URL=https://api.pocketbrew.app
EXPO_PUBLIC_API_TIMEOUT=30000

# Analytics
EXPO_PUBLIC_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx

# Apple Configuration (for TestFlight)
APPLE_ID=your-apple-id@example.com
APPLE_PASSWORD=your-app-specific-password
APPLE_TEAM_ID=XXXXXXXXXX

# Google Configuration (for Play Console)
ANDROID_SERVICE_ACCOUNT_JSON=./android-service-account.json

# Security
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# Database Connection Pool
DATABASE_POOL_SIZE=20
DATABASE_IDLE_TIMEOUT=30000

# EAS Build Configuration
EAS_BUILD_PROFILE=production
PROVISIONING_PROFILE_SPECIFIER=match AppStore Pocket\ Brew
CODE_SIGNING_STYLE=Automatic
